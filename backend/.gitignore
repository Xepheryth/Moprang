# Backend-specific .gitignore

# Dependencies
node_modules/
package-lock.json
yarn.lock

# Environment variables (NEVER commit .env)
.env
.env.local
.env.*.local

# SSL/TLS Certificates
*.pem
*.key
*.crt
*.csr
server.key
server.crt

# Database files
*.db
*.sqlite
*.sqlite3
kans.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Temp files
tmp/
temp/
*.tmp
*.bak

# Node/NPM
.npm
.eslintcache
.node_repl_history
*.tgz
.yarn-integrity
.env.test.local
.cache
.next
out
dist
build

# Misc
.tern-port
